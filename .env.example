# Frontend polling interval (milliseconds)
VITE_LIVE_SCORE_UI_POLL_INTERVAL_MS="2500"

# Vite dev server API proxy target (/api -> this backend)
LIVE_SCORE_BACKEND_PROXY_TARGET="http://127.0.0.1:3101"

# Docker Compose UI port mapping host:container(80)
LIVE_SCORE_UI_PORT="8080"

# Live scoreboard backend bind settings
LIVE_SCORE_BIND_HOST="0.0.0.0"
LIVE_SCORE_PORT="3101"

# GameServer endpoints
LIVE_SCORE_GAMESERVER_BASE_URL="http://10.66.30.100"
LIVE_SCORE_SCOREBOARD_PATH="/competition/scoreboard.json"
LIVE_SCORE_STATUS_PATH="/competition/status.json"

# Backend polling behavior
LIVE_SCORE_POLL_INTERVAL_MS="4000"
LIVE_SCORE_REQUEST_TIMEOUT_MS="3000"
LIVE_SCORE_MAX_EVENTS="40"
LIVE_SCORE_CORS_ORIGIN="*"

# Optional fallback snapshot overrides (prefer absolute paths if you set these)
# LIVE_SCORE_FALLBACK_SCOREBOARD_FILE="/path/to/scoreboard.json"
# LIVE_SCORE_FALLBACK_STATUS_FILE="/path/to/status.json"
